{
  "name": "@hua123an/universal-agent",
  "version": "1.0.0",
  "description": "Universal coding agent CLI that combines Anthropic Claude Agent SDK and OpenAI Agents SDK.",
  "main": "./dist/index.js",
  "bin": {
    "universal-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "keywords": [
    "agent",
    "anthropic",
    "cli",
    "mcp",
    "openai",
    "typescript"
  ],
  "author": "hua123an",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hua123an/universal-agent.git"
  },
  "homepage": "https://github.com/hua123an/universal-agent#readme",
  "bugs": {
    "url": "https://github.com/hua123an/universal-agent/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@openai/agents": "^0.8.3",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
